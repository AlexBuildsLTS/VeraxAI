{
  "expo": {
    "name": "veraxai",
    "slug": "veraxai",
    "version": "1.0.0",
    "scheme": "veraxai",
    "orientation": "portrait",
    "platforms": ["ios", "android", "web"],
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.veraxai.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "This app needs access to the microphone to transcribe your speech in real-time.",
        "NSPhotoLibraryUsageDescription": "This app needs access to your library to import video files for transcription.",
        "NSAppleMusicUsageDescription": "This app needs access to your audio files for transcription.",
        "UIBackgroundModes": ["audio"]
      }
    },
    "android": {
      "package": "com.veraxai.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/favicon.png",
        "backgroundColor": "#020205"
      },
      "splash": {
        "image": "./assets/favicon.png",
        "resizeMode": "contain",
        "backgroundColor": "#020205"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.ACCESS_WIFI_STATE",
        "android.permission.VIBRATE",
        "android.permission.WAKE_LOCK"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "jsEngine": "jsc",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-video",
      "expo-document-picker",
      "expo-audio",
      "expo-asset",
      "expo-file-system",
      "expo-web-browser",
      "expo-image",
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "2.1.20",
            "kspVersion": "2.1.20-1.0.29"
          }
        }
      ],
      "expo-sharing"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c1d22081-046b-4228-afc5-35389f7d88a2"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/c1d22081-046b-4228-afc5-35389f7d88a2"
    }
  }
}