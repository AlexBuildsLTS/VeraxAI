{
  "expo": {
    "name": "transcriber-pro",
    "slug": "transcriber-pro",
    "version": "1.0.0",
    "scheme": "transcriber-pro",
    "orientation": "portrait",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.transcriberpro.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "This app needs access to the microphone to transcribe your speech in real-time.",
        "NSPhotoLibraryUsageDescription": "This app needs access to your library to import video files for transcription.",
        "NSAppleMusicUsageDescription": "This app needs access to your audio files for transcription.",
        "UIBackgroundModes": [
          "audio"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#05050A"
      },
      "package": "com.transcriberpro.app",
      "permissions": [
        "RECORD_AUDIO",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "jsEngine": "jsc"
    },
    "extra": {
      "eas": {
        "projectId": "d1b9c8c7-5a0b-4f1e-9c3a-2b6e5f8a9c3d"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-video",
      "expo-document-picker",
      "expo-audio",
      "expo-asset",
      "expo-file-system",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
